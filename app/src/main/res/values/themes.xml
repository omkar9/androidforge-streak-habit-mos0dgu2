<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.StreakHabit" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Theme for the splash screen -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background to match your app's background color -->
        <item name="windowSplashScreenBackground">@color/background</item> 
        <!-- Set the drawable to use as the icon in the center of the splash screen -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <!-- Set the duration of the splash screen animation. -->
        <item name="windowSplashScreenAnimationDuration">500</item>
        <!-- Set the theme of the Activity that follows the splash screen. -->
        <item name="postSplashScreenTheme">@style/Theme.StreakHabit</item>
    </style>
</resources>